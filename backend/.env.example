# Server
PORT=3000
NODE_ENV=production

# API Keys (NEVER commit .env with real keys)
DEEPL_API_KEY=your_deepl_api_key_here
XAI_API_KEY=your_xai_api_key_here

# JWT Secret for device authentication
JWT_SECRET=your_random_jwt_secret_here_min_64_chars

# Rate Limiting
RATE_LIMIT_FREE_DAILY=3
RATE_LIMIT_PRO_PER_MINUTE=30
RATE_LIMIT_GLOBAL_PER_MINUTE=1000
